# Copy this file to .env.local and fill in the values from your Supabase dashboard.
# .env.local is gitignored; .env.example is committed as a template for new contributors.
#
# The "anon key" is what Supabase used to call it. It's now called the
# "publishable key" (format: sb_publishable_...). Either value works.

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key
